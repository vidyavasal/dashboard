# ===========================================
# IODE Business Tracker — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local — it contains secrets.
#
# This app SHARES the same Neon database as the main marketing site
# (iode / Vidyavasal). Point DATABASE_URL at the SAME connection string.

# Staging Database (default for local development)
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Production Database
DATABASE_URL_PRODUCTION="postgresql://user:password@host/neondb?sslmode=require"

# Admin auth — the tracker is the SINGLE admin panel. Use the same value as the
# main site only if you want a shared login cookie across both domains.
ADMIN_JWT_SECRET="change-me-in-production"

# ImageKit — for university/course/blog image uploads (ported from main site).
# Same account as the main site unless you split staging/prod media.
IMAGEKIT_PUBLIC_KEY=""
IMAGEKIT_PRIVATE_KEY=""
IMAGEKIT_URL_ENDPOINT=""

# Credential vault — encrypts the university student-portal logins stored on a
# profile so they can be re-shared. The password key is derived from a MEMORIZED
# admin passphrase (never stored) + this server-side pepper. Generate both with:
#   npm run cred:setup -- "the memorized passphrase"
# Set the SAME values in both Vercel environments. Changing the pepper makes
# existing stored passwords unrecoverable.
PROFILE_CRED_PEPPER=""
PROFILE_PASSPHRASE_VERIFIER=""

# Environment
NODE_ENV=development
